[Unit]
Description=LUMINA CMS Flask backend
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/lumina-cms
Environment=PATH=/opt/lumina-cms/venv/bin
ExecStart=/opt/lumina-cms/venv/bin/gunicorn -w 2 -b 127.0.0.1:8787 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
